# Get your project ID at https://cloud.walletconnect.com
# Required for browser wallet connections (MetaMask, Rainbow, etc.)
# Not needed for MiniPay — MiniPay auto-connects via the injected provider
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here
VITE_RPC=https://forno.celo-sepolia.celo-testnet.org
VITE_SIGNER_URL=http://localhost:3001

# Web3Auth (social login — Google, Twitter, email)
# Get your Client ID at https://dashboard.web3auth.io → Create Project → Client ID
# Network: sapphire_mainnet for production, sapphire_devnet for testing
VITE_WEB3AUTH_CLIENT_ID=your_web3auth_client_id_here
# sapphire_devnet  = permissive, works on localhost without dashboard whitelist
# sapphire_mainnet = strict, requires domain whitelisted at dashboard.web3auth.io
VITE_WEB3AUTH_NETWORK=sapphire_devnet
